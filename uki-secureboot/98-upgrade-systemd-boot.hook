# /etc/pacman.d/hooks/98-sign-bootloader.hook
# systemd-boot update after systemd upgrades.
# Runs at priority 98

[Trigger]
Type = Package
Operation = Upgrade
Target = systemd

[Action]
Description = Gracefully upgrading systemd-boot...
When = PostTransaction
Exec = /usr/bin/systemctl restart systemd-boot-update.service